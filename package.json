{
  "homepage": "https://sudamchakor.github.io/smart-fund-manager/",
  "name": "smart-fund-manager",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.18.0",
    "@mui/material": "^5.13.0",
    "@mui/x-date-pickers": "^6.3.1",
    "@reduxjs/toolkit": "^2.11.2",
    "dayjs": "^1.11.7",
    "firebase": "^12.12.1",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.5.28",
    "notistack": "^3.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-quill": "^2.0.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.22.3",
    "react-scripts": "5.0.1",
    "recharts": "^2.5.0",
    "redux-persist": "^6.0.0",
    "reselect": "^5.1.0",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build && node inline-css.js",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build -t",
    "analyze": "npm run build && source-map-explorer 'build/static/js/*.js'",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\""
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.0.0",
    "gh-pages": "^6.3.0",
    "prettier": "^3.0.0",
    "redux-mock-store": "^1.5.4",
    "source-map-explorer": "^2.5.3"
  },
  "keywords": [
    "emi",
    "calculator",
    "loan",
    "finance",
    "react",
    "interest-calculator",
    "mortgage",
    "web-app"
  ],
  "jest": {
    "moduleNameMapper": {
      "^@/src/(.*)$": "<rootDir>/src/$1"
    }
  }
}
